{
  "schema_version": 1,
  "app": {
    "results_album_name": "AI Search Results",
    "log_level": "info"
  },
  "storage": {
    "root_dir": ".data",
    "catalog_db_path": ".data/catalog-store.json",
    "vector_backend": "qdrant",
    "vector_service_url": "http://127.0.0.1:6333",
    "vector_collection_name": "media-index",
    "vector_distance": "cosine",
    "vector_timeout_ms": 10000
  },
  "scanner": {
    "include_images": true,
    "include_videos": true,
    "batch_size": 200
  },
  "extractor": {
    "image_thumbnail_size": 224,
    "video_strategy": "storyboard",
    "allow_network_access": true
  },
  "indexer": {
    "write_batch_size": 64,
    "extraction_batch_size": 200,
    "reindex_mode": "incremental"
  },
  "retriever": {
    "default_limit": 50,
    "album_write_mode": "replace",
    "write_to_photos_results_album": true
  },
  "embedding": {
    "provider": "open-clip",
    "candidate_preset": "fallback-safe",
    "model": "ViT-H-14",
    "pretrained": "laion2b_s32b_b79k",
    "device": "auto",
    "target_resolution": 224,
    "normalize": true,
    "batch_size": 2,
    "benchmark_batch_size": 2,
    "benchmark_asset_limit": 50
  },
  "debug": {
    "save_diagnostics": false
  }
}
